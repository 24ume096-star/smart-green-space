NODE_ENV=development
PORT=8080

# Frontend origin(s), comma-separated
CORS_ORIGIN=http://localhost:5173,http://localhost:4173

# Prisma/Postgres (TimescaleDB)
DATABASE_URL=postgresql://sgs:sgs_password@localhost:5432/greenspace?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=change_me_access_secret_min_16_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_16_chars
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=7

# Optional: S3 uploads
AWS_REGION=
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Controls
SWAGGER_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300
TRUST_PROXY=false


