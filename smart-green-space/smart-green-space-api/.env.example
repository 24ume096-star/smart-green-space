NODE_ENV=development
PORT=3000

# Frontend origin(s), comma-separated
CORS_ORIGIN=http://localhost:5173

# Prisma/Postgres (TimescaleDB)
DATABASE_URL=postgresql://sgs:sgs_password@localhost:5432/greenspace?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=change_me_access_secret_min_16_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_16_chars
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=7

# Optional: S3 uploads
AWS_REGION=
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Optional: HMAC secret for POST /api/v1/satellite/webhook/sentinel (required in production)
SENTINEL_WEBHOOK_SECRET=

# Controls
SWAGGER_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300
TRUST_PROXY=false

# Optional (unused placeholders for future integrations)
FRONTEND_URL=http://localhost:5173
PYTHON_AI_SERVICE_URL=http://localhost:8000
OPENWEATHER_API_KEY=
BULL_REDIS_URL=redis://localhost:6379

